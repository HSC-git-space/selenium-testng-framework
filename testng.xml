<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="LoginTestSuite" parallel="methods" thread-count="2">

    <listeners>
        <listener class-name="com.sdet.listeners.AnnotationTransformer"/>
    </listeners>

    <test name="LoginTests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

</suite>